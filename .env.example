# 複製這個檔成 .env,再把值填進去(.env 不會進 git)
#   cp .env.example .env

# 【必填】Gemini API key,到 https://aistudio.google.com/apikey 免費申請
GEMINI_API_KEY=

# 【選填】生成用的模型;不填則用 config.py 預設 gemini-2.5-flash
#   gemini-2.5-flash(穩定) / gemini-3.5-flash(較新、尖峰易 503)
GEMINI_MODEL=

# 【選填】是否顯示來源。不填預設 true(開發模式)
#   true  → 回答標「(來源:xxx.md)」+ 介面列出檢索來源,方便驗證 RAG
#   false → 對外模式:回答不暴露檔名、介面也不顯示來源(模型內部仍只根據語料)
SHOW_SOURCES=
